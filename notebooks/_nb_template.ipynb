    "# Logger\n",
    "import logging\n",
    "import yaml\n",
    "\n",
    "with open('./config/log.yml', 'r') as f:\n",
    "    config = yaml.safe_load(f.read())\n",
    "    logging.config.dictConfig(config)\n",
    "\n",
    "log = logging.getLogger('ib_log')"
